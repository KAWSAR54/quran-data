{
  "surah_id": 102,
  "pronunciations": [
    "আলহা-কুমুত তাকা-ছুর।",
    "হাত্তা- যুরতুমুল মাক্বা-বির।",
    "কাল্লা- সাওফা তাউলামূন।",
    "ছুম্মা কাল্লা- সাওফা তাউলামূন।",
    "কাল্লা- লাও তাউলামূনা ইলমাল ইয়াক্বীন।",
    "লাতারাউন্নাল জাহীম।",
    "ছুম্মা লাতারাউন্নাহা- আইনাল ইয়াক্বীন।",
    "ছুম্মা লাতুসআলুন্না ইয়াওমাইযিন আনিন নাঈম।"
  ]
}
