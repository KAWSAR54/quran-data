{
  "surah_id": 93,
  "pronunciations": [
    "ওয়াদ দ্বোহা।",
    "ওয়াল লাইলি ইযা সাজা।",
    "মা ওয়াদ্দায়াকা রব্বুকা ওয়ামা ক্বালা।",
    "ওয়ালাল আখিরাতু খইরুল লাকা মিনাল ঊলা।",
    "ওয়ালাসাওফা ইউয়ত্বীকা রব্বুকা ফাতারদ্বোয়া।",
    "আলাম ইয়াজিদকা ইয়াতীমান ফাআওয়া।",
    "ওয়া ওয়াজাদাকা দ্বোয়াল্লান ফাহাদা।",
    "ওয়া ওয়াজাদাকা আয়িলান ফাআগনা।",
    "ফাআম্মাল ইয়াতীমা ফালা তাক্বহার।",
    "ওয়া আম্মাস সায়িলা ফালা তানহার।",
    "ওয়া আম্মা বিনিয়মাতি রব্বিকা ফাহাদ্দিছ।"
  ]
}
