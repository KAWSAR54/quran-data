{
  "surah_id": 104,
  "pronunciations": [
    "ওয়াইলুল লিকুল্লি হুমাযাতিল লুমাযাহ।",
    "আল্লাযী জামাআ মা-লাওঁ ওয়া আদ্দাদাহ।",
    "ইয়াহসাবু আন্না মা-লাহূ আখলাদাহ।",
    "কাল্লা- লাইয়ুমবাযান্না ফিল হুত্বামাহ।",
    "ওয়া মা আদরা-কা মাল হুত্বামাহ।",
    "না-রুল্লা-হিল মূক্বাদাহ।",
    "আল্লাতী তাত্ত্বোলিউ আলাল আফইদাহ।",
    "ইন্নাহা- আলাইহিম মু'সদাহ।",
    "ফী আমাদিম মুমাদ্দাদাহ।"
  ]
}
