{
  "surah_id": 84,
  "pronunciations": [
    "ইযাস সামাউন শাক্বক্বাত।",
    "ওয়া আযিনাত লিরব্বিহা ওয়া হুক্বক্বাত।",
    "ওয়া ইযাল আরদ্বু মুদ্দাত।",
    "ওয়া আলক্বাত মা ফীহা ওয়া তাখাল্লাত।",
    "ওয়া আযিনাত লিরব্বিহা ওয়া হুক্বক্বাত।",
    "ইয়া আইয়্যুহাল ইনসানু ইন্নাকা কাদিহুন ইলা রব্বিকা কাদহান ফামুলাক্বীহ।",
    "ফাআম্মা মান ঊতিয়া কিতাবাহূ বিইয়ামীনীহ।",
    "ফাসাওফা ইয়ুহাসাবু হিসাবান ইয়াসীরা।",
    "ওয়া ইয়ানক্বালিবু ইলা আহলিহী মাসরূরা।",
    "ওয়া আম্মা মান ঊতিয়া কিতাবাহূ ওয়ারায়া যোয়াহরিহ।",
    "ফাসাওফা ইয়াদঊ ছুবূরা।",
    "ওয়া ইয়াসলা সাঈরা।",
    "ইন্নাহূ কানা ফী আহলিহী মাসরূরা।",
    "ইন্নাহূ যোয়ান্না আল লান ইয়াহূর।",
    "বালা ইন্না রব্বাহূ কানা বিহী বাসীরা।",
    "ফালা উক্বসিমু বিশশাফাক্ব।",
    "ওয়াললাইলি ওয়ামা ওয়াসাক্ব।",
    "ওয়ালক্বামারি ইযাত তাসাক্ব।",
    "লাতারকাবুননা ত্বোবাক্বান আন ত্বোবাক্ব।",
    "ফামা লাহুম লা ইউউমিনূন।",
    "ওয়া ইযা ক্বুরিআ আলাইহিমুল ক্বুরআনু লা ইয়াসজুদূন।",
    "বালিল্লাযীনা কাফারূ ইউকাযযিবূন।",
    "ওয়াল্লাহু আলামু বিমা ইয়ূঊন।",
    "ফাবাশশিরহুম বিআযাবিন আলীম।",
    "ইল্লাল্লাযীনা আমানূ ওয়া আমিলুস সোয়ালিহাতি লাহুম আজরুন গইরু মামনূন।"
  ]
}
