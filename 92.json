{
  "surah_id": 92,
  "pronunciations": [
    "ওয়াল লাইলি ইযা ইয়াগশা।",
    "ওয়ান নাহারি ইযা তাজাল্লা।",
    "ওয়ামা খালাক্বায যাকারা ওয়াল উনছা।",
    "ইন্না সায়াকুম লাশাত্তা।",
    "ফাআম্মা মান আত্বোয়া ওয়াত্তাক্বা।",
    "ওয়া সাদ্দাক্বা বিল হুসনা।",
    "ফাসানুয়াসসিরুহূ লিল ইউসরা।",
    "ওয়া আম্মা মাম বাখিলা ওয়াসতাগনা।",
    "ওয়া কাযযাবা বিল হুসনা।",
    "ফাসানুয়াসসিরুহূ লিল উসরা।",
    "ওয়ামা ইউগনী আনহু মালুহূ ইযা তারাদদা।",
    "ইন্না আলাইনা লাল হুদা।",
    "ওয়া ইন্না লানা লাল আখিরাতা ওয়াল ঊলা।",
    "ফাআনযারতুকুম নারান তালাযযা।",
    "লা ইয়াসলাহা ইল্লাল আশক্বা।",
    "আল্লাযী কাযযাবা ওয়া তাওয়াল্লা।",
    "ওয়া সাইয়ুজান্নাবুহাল আতক্বা।",
    "আল্লাযী ইউউতী মালুহূ ইয়াতাযাক্কা।",
    "ওয়ামা লিআহাদিন ইনদাহূ মিন নিয়মাতিন তুজযা।",
    "ইল্লাবতিগায়া ওয়াজহি রব্বিহিল আলা।",
    "ওয়ালাসাওফা ইয়ারদ্বোয়া।"
  ]
}
