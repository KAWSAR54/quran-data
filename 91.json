{
  "surah_id": 91,
  "pronunciations": [
    "ওয়াশ শামসি ওয়া দ্বুহাহা।",
    "ওয়াল ক্বামারি ইযা তালাহা।",
    "ওয়ান নাহারি ইযা জাল্লাহা।",
    "ওয়াল লাইলি ইযা ইয়াগশাহা।",
    "ওয়াস সামায়ি ওয়ামা বানাহা।",
    "ওয়াল আরদ্বি ওয়ামা ত্বোহাহা।",
    "ওয়া নাফসিউ ওয়ামা সাওওয়াহা।",
    "ফাআলহামাহা ফুজূরাহা ওয়া তাক্বওয়াহা।",
    "ক্বাদ আফলাহা মান যাক্কাহা।",
    "ওয়া ক্বাদ খাবা মান দাসসাহা।",
    "কাযযাবাত ছামূদু বিত্বগওয়াহা।",
    "ইযিম বাআছা আশক্বাহা।",
    "ফাক্বালা লাহুম রসূলুল্লাহি নাক্বাতাল্লাহি ওয়া সুক্বইয়াহা।",
    "ফাকাযযাবূহু ফাআক্বারূহা ফাদামদামা আলাইহিম রব্বুহুম বিযামবিহিম ফাসাওওয়াহা।",
    "ওয়ালা ইয়াখাফু উক্ববাহা।"
  ]
}
