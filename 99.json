{
  "surah_id": 99,
  "pronunciations": [
    "ইযা যুলযিলাতিল আরদ্বু যিলযালাহা।",
    "ওয়া আখরাজাতিল আরদ্বু আছক্বালাহা।",
    "ওয়া ক্বালাল ইনসানু মা লাহা।",
    "ইয়াওমাইযিন তুহাদ্দিছু আখবারাহা।",
    "বিআন্না রব্বাকা আওহা লাহা।",
    "ইয়াওমাইযিঁই ইয়াসদুরুন্নাসু আশতাতাল লিইউরাও আয়মালাহুম।",
    "ফামাইঁ ইয়াযমাল মিছক্বালা যাররাতিন খইরাইঁ ইয়ারাহ।",
    "ওয়ামাইঁ ইয়াযমাল মিছক্বালা যাররাতিন শাররাইঁ ইয়ারাহ।"
  ]
}
