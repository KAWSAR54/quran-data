{
  "surah_id": 1,
  "pronunciations": [
    "বিসমিল্লাহির রাহমা-নির রাহীম",
    "আলহামদু লিল্লাহি রব্বিল আলামীন।",
    "আর রাহমা-নির রাহীম।",
    "মা-লিকি ইয়াওমিদ্দ্বীন।",
    "ইয়্যাকা না’বুদু ওয়া ইয়্যাকা নাসতা’ঈন।",
    "ইহদিনাস সিরাতাল মুস্তাক্বীম।",
    "সিরাতাল্লাযীনা আনআমতা আলাইহিম, গইরিল মাগদূবি আলাইহিম ওয়ালাদ দো-ল্লীন।"
  ]
}