{
  "surah_id": 100,
  "pronunciations": [
    "ওয়াল আ-দিয়া-তি দ্বাবহা।",
    "ফাল মূরিয়া-তি ক্বাদহা।",
    "ফাল মুগীরা-তি সুবহা।",
    "ফাআছারনা বিহী নাক্বআ।",
    "ফাওয়াসাত্বনা বিহী জামআ।",
    "ইন্নাল ইনসা-না লিরাব্বিহী লাকানূদ।",
    "ওয়া ইন্নাহূ আলা- যা-লিকা লাশাহীদ।",
    "ওয়া ইন্নাহূ লিহুব্বিল খইরি লাশাদীদ।",
    "আফালা- ইয়াউলামু ইযা- বুউছিরা মা- ফিল ক্বুবূর।",
    "ওয়া হুসসিলা মা- ফিস সুদূর।",
    "ইন্না রব্বাহুম বিহিম ইয়াওমাইযিল লাখাবীর।"
  ]
}
