{
  "surah_id": 90,
  "pronunciations": [
    "লা উক্বসিমু বিহাযাল বালাদ।",
    "ওয়া আনতা হিল্লুম বিহাযাল বালাদ।",
    "ওয়া ওয়ালিদিউ ওয়ামা ওয়ালাদ।",
    "লাক্বাদ খালাক্বনাল ইনসানা ফী কাবাদ।",
    "আইয়াহসাবু আল লাই ইয়াক্বদিরা আলাইহি আহাদ।",
    "ইয়াক্বূলু আহলাকতু মালাল লুবাদা।",
    "আইয়াহসাবু আল লাম ইয়ারাহূ আহাদ।",
    "আলাম নাজআল লাহূ আইনাইন।",
    "ওয়া লিসানাও ওয়া শাফাতাইন।",
    "ওয়া হাদাইনাহুন নাজদাইন।",
    "ফালাক্বতাহামাল আক্বাবাহ।",
    "ওয়ামা আদরাকা মাল আক্বাবাহ।",
    "ফাক্কু রাক্বাবাহ।",
    "আও ইতআমুন ফী ইয়াওমিন যী মাসগাবাহ।",
    "ইয়াতীমান যা মাক্বরাবাহ।",
    "আও মিসকীনান যা মাতরাবাহ।",
    "ছুম্মা কানা মিনাল্লাযীনা আমানূ ওয়া তাওয়াসাও বিস সাবরি ওয়া তাওয়াসাও বিল মারহামাহ।",
    "উলায়িকা আসহাবুল মাইমানাহ।",
    "ওয়াল্লাযীনা কাফারূ বিআয়াতিনা হুম আসহাবুল মাশআমাহ।",
    "আলাইহিম নারুম মুওসাদাহ।"
  ]
}
