{
  "surah_id": 87,
  "pronunciations": [
    "সাব্বিহিসমা রব্বিকাল আলা।",
    "আল্লাযী খালাক্বা ফাসাওওয়া।",
    "ওয়াল্লাযী ক্বাদ্দারা ফাহাদা।",
    "ওয়াল্লাযী আখরাজাল মারআ।",
    "ফাজাআলাহূ গুছাআন আহওয়া।",
    "সানুক্বরিউকা ফালা তানসা।",
    "ইল্লা মা শাআল্লাহু ইন্নাহূ ইয়ালামুল জাহরা ওয়ামা ইয়াখফা।",
    "ওয়ানুয়াসসিরুকা লিল ইউসরা।",
    "ফাযাক্কির ইন নাফাআতিয যিকরা।",
    "সাইয়াযযাককারু মান ইয়াখশা।",
    "ওয়া ইয়াতাজান্নাবুহাল আশক্বা।",
    "আল্লাযী ইয়াসলান নারাল কুবরা।",
    "ছুম্মা লা ইয়ামূতু ফীহা ওয়ালা ইয়াহইয়া।",
    "ক্বাদ আফলাহা মান তাযাক্কা।",
    "ওয়া যাকারাসমা রব্বিহী ফাসাল্লা।",
    "বাল তুছিরূনাল হায়াতাদ দুনিয়া।",
    "ওয়াল আখিরাতু খইরুন ওয়া আবক্বা।",
    "ইন্না হাযা লাফিস সুহুফিল ঊলা।",
    "সুহুফি ইবরাহীমা ওয়া মূসা।"
  ]
}
