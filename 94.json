{
  "surah_id": 94,
  "pronunciations": [
    "আলাম নাশরাহ লাকা সাদরাক।",
    "ওয়া ওয়াদ্বআনা আনকা উইযরাক।",
    "আল্লাযী আনক্বাদ্বা যোহরাক।",
    "ওয়া রাফআনা লাকা যিকরাক।",
    "ফাইন্না মায়াল উসরি ইউসরা।",
    "ইন্না মায়াল উসরি ইউসরা।",
    "ফাইযা ফারগতা ফানসাব।",
    "ওয়া ইলা রব্বিকা ফারগাব।"
  ]
}
