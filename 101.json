{
  "surah_id": 101,
  "pronunciations": [
    "আল ক্বারিআহ।",
    "মাল ক্বারিআহ।",
    "ওয়ামা আদরাকা মাল ক্বারিআহ।",
    "ইয়াওমা ইয়াকূনুন্নাসু কাল ফারশিল মাবছূছ।",
    "ওয়াতাকূনুল জিবালু কাল ইহনিল মানফূশ।",
    "ফাআম্মা মান ছাক্বুলাত মাওয়াযীনুহ।",
    "ফাহুওয়া ফী ঈশাতির রদ্বিয়াহ।",
    "ওয়া আম্মা মান খফফাত মাওয়াযীনুহ।",
    "ফাউম্মুহূ হাওয়িয়াহ।",
    "ওয়ামা আদরাকা মা হিয়াহ।",
    "নারুন হামিয়াহ।"
  ]
}
