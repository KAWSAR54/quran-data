{
  "surah_id": 96,
  "pronunciations": [
    "ইক্বরা বিসমি রব্বিকাল্লাযী খালাক্ব।",
    "খালাক্বাল ইনসানা মিন আলাক্ব।",
    "ইক্বরা ওয়া রব্বুকাল আকরাম।",
    "আল্লাযী আল্লামা বিল ক্বালাম।",
    "আল্লামাল ইনসানা মা লাম ইয়ালাম।",
    "কাল্লা ইন্নাল ইনসানা লাইয়াত্বগা।",
    "আর রাআহুস তাগনা।",
    "ইন্না ইলা রব্বিকার রুজয়া।",
    "আরাআইতাল্লাযী ইয়ানহা।",
    "আবদান ইযা সাল্লা।",
    "আরাআইতা ইন কানা আলাল হুদা।",
    "আও আমারা বিত তাক্বওয়া।",
    "আরাআইতা ইন কাযযাবা ওয়া তাওয়াল্লা।",
    "আলাম ইয়ালাম বিআন্নাল্লাহা ইয়ারা।",
    "কাল্লা লায়িল লাম ইয়ানতাহি লানাসফাআম বিন নাসিয়াহ।",
    "নাসিয়াতিন কাযিবাতিন খাতিয়াহ।",
    "ফালইয়াদউ নাদিয়াহ।",
    "সানাদউয যাবানিয়াহ।",
    "কাল্লা লা তুত্বিয়হু ওয়াসজুদ ওয়াক্বতারিব।"
  ]
}
