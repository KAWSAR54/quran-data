{
  "surah_id": 86,
  "pronunciations": [
    "ওয়াস সামায়ি ওয়াত ত্বারিক্ব।",
    "ওয়ামা আদরাকা মাত ত্বারিক্ব।",
    "আন নাজমুছ ছাক্বিব।",
    "ইন কুল্লু নাফসিল লাম্মা আলাইহা হাফিয।",
    "ফালইয়ানযুরিল ইনসানু মিম্মা খুলিক্ব।",
    "খুলিক্বা মিম মায়িন দাফিক্ব।",
    "ইয়াখরুজু মিম বাইনিস সুলবি ওয়াত তারায়িব।",
    "ইন্নাহূ আলা রজইহী লাক্বাদীর।",
    "ইয়াওমা তুবলাস সারায়ির।",
    "ফামা লাহূ মিন ক্বুউওয়াতিন ওয়ালা নাসির।",
    "ওয়াস সামায়ি যাতির রজই।",
    "ওয়ালআরদ্বি যাতিস সদই।",
    "ইন্নাহূ লাক্বওলুন ফাসল।",
    "ওয়ামা হুওয়া বিলহাযল।",
    "ইন্নাহুম ইয়াকীদূনা কাইদা।",
    "ওয়া আকীদু কাইদা।",
    "ফামাহহিলিল কাফিরীনা আমহিলহুম রুওয়াইদা।"
  ]
}
