{
  "surah_id": 88,
  "pronunciations": [
    "হাল আতাকা হাদীছুল গাশিয়াহ।",
    "উজুহুই ইয়াওমাইয়িযিন খাশিয়াহ।",
    "আমিলাতুন নাসিবাহ।",
    "তাসলা নারান হামিয়াহ।",
    "তুসক্বা মিন আইনিন আনিয়াহ।",
    "লাইসা লাহুম ত্বোআমুন ইল্লা মিন দ্বরীয়।",
    "লা ইউসমিনু ওয়ালা ইউগনী মিন জূয়।",
    "উজুহুই ইয়াওমাইয়িযিন নায়িমাহ।",
    "লিসায়িহা রাদিয়াহ।",
    "ফী জান্নাতিন আলিয়াহ।",
    "লা তাসমাউ ফীহা লাগিয়াহ।",
    "ফীহা আইনুন জারিয়াহ।",
    "ফীহা সুরুরুন মারফূআহ।",
    "ওয়া আকওয়াবুম মাওদ্বূআহ।",
    "ওয়া নামারিক্বু মাসফূফাহ।",
    "ওয়া যারাবিয়্যু মাবছূছাহ।",
    "আফালা ইয়ানযুরূনা ইলাল ইবিলি কাইফা খুলিক্বাত।",
    "ওয়া ইলাস সামায়ি কাইফা রুফিয়াত।",
    "ওয়া ইলাল জিবালি কাইফা নুসিবাত।",
    "ওয়া ইলাল আরদ্বি কাইফা সুতিহাত।",
    "ফাযাক্কির ইন্নামা আনতা মুযাক্কির।",
    "লাসতা আলাইহিম বিমুসাইত্বির।",
    "ইল্লা মান তাওয়াল্লা ওয়া কাফার।",
    "ফাইয়ুআযযিবুহুল্লাহুল আযাবাল আকবার।",
    "ইন্না ইলাইনা ইয়াবাহুম।",
    "ছুম্মা ইন্না আলাইনা হিসাবাহুম।"
  ]
}
